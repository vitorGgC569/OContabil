<UserControl x:Class="ContaDocAI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <StackPanel>
        <!-- ═══ Stat Cards ═══ -->
        <UniformGrid Columns="4" Margin="0,0,0,24">
            <!-- Processados Hoje -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                <Border.Effect><DropShadowEffect ShadowDepth="0" BlurRadius="0" Opacity="0"/></Border.Effect>
                <Grid>
                    <Rectangle Height="2" VerticalAlignment="Top" Margin="-20,-20,-20,0" RadiusX="10" RadiusY="0"
                               Fill="{StaticResource AccentBrush}" Opacity="0.6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Border Width="44" Height="44" CornerRadius="8" Background="{StaticResource AccentGlowBrush}">
                            <TextBlock Text="📄" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="txtProcessed" Text="342" FontSize="28" FontWeight="ExtraBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                            <TextBlock Text="Processados hoje" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Border Background="{StaticResource SuccessBgBrush}" CornerRadius="10" Padding="8,2" Margin="0,4,0,0"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="↑ +18%" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Aguardando Validacao -->
            <Border Style="{StaticResource CardStyle}" Margin="6,0">
                <Grid>
                    <Rectangle Height="2" VerticalAlignment="Top" Margin="-20,-20,-20,0"
                               Fill="{StaticResource WarningBrush}" Opacity="0.6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Border Width="44" Height="44" CornerRadius="8" Background="{StaticResource WarningBgBrush}">
                            <TextBlock Text="⏳" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="5" FontSize="28" FontWeight="ExtraBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Aguardando validacao" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Border Background="{StaticResource ErrorBgBrush}" CornerRadius="10" Padding="8,2" Margin="0,4,0,0"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="↓ -12%" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource ErrorBrush}"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Erros -->
            <Border Style="{StaticResource CardStyle}" Margin="6,0">
                <Grid>
                    <Rectangle Height="2" VerticalAlignment="Top" Margin="-20,-20,-20,0"
                               Fill="{StaticResource ErrorBrush}" Opacity="0.6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Border Width="44" Height="44" CornerRadius="8" Background="{StaticResource ErrorBgBrush}">
                            <TextBlock Text="⚠️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="2" FontSize="28" FontWeight="ExtraBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Erros de leitura" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Acuracia -->
            <Border Style="{StaticResource CardStyle}" Margin="12,0,0,0">
                <Grid>
                    <Rectangle Height="2" VerticalAlignment="Top" Margin="-20,-20,-20,0"
                               Fill="{StaticResource SuccessBrush}" Opacity="0.6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Border Width="44" Height="44" CornerRadius="8" Background="{StaticResource SuccessBgBrush}">
                            <TextBlock Text="✓" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{StaticResource SuccessBrush}"/>
                        </Border>
                        <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="96.4%" FontSize="28" FontWeight="ExtraBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Acuracia GLiNER 2" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Border Background="{StaticResource SuccessBgBrush}" CornerRadius="10" Padding="8,2" Margin="0,4,0,0"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="↑ +0.8%" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </UniformGrid>

        <!-- ═══ Volume Chart + Activity ═══ -->
        <Grid Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Volume Chart -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Volume de Processamento" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Ultimos 14 dias · 8.743 docs/mes" FontSize="12"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                        </StackPanel>
                        <Border DockPanel.Dock="Right" Background="{StaticResource InfoBgBrush}" CornerRadius="10"
                                Padding="10,4" VerticalAlignment="Center" BorderBrush="#4D3b82f6" BorderThickness="1">
                            <TextBlock Text="Tempo medio: 1.8s" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource InfoBrush}"/>
                        </Border>
                    </DockPanel>

                    <!-- Chart Bars -->
                    <Canvas x:Name="chartCanvas" Height="180" Margin="0,8,0,8"/>

                    <!-- Chart Labels -->
                    <ItemsControl x:Name="chartLabels">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Recent Activity -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Atividade Recente" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Ultimo processamento: hoje as 18:30" FontSize="12"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                        </StackPanel>
                    </DockPanel>
                    <ItemsControl x:Name="activityList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" CornerRadius="4" Margin="0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Time}" FontSize="11"
                                                   Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Action}" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Client}" FontSize="12"
                                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Doc}" FontSize="10"
                                                   Foreground="{StaticResource TextTertiaryBrush}"
                                                   FontFamily="Consolas" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ Client Table ═══ -->
        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <DockPanel Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Clientes por Volume" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="47 clientes ativos" FontSize="12"
                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                    </StackPanel>
                </DockPanel>

                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8">
                    <DataGrid x:Name="clientsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              Background="Transparent" BorderThickness="0"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              FontFamily="Segoe UI" FontSize="13"
                              RowBackground="Transparent" AlternatingRowBackground="Transparent"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                              HeadersVisibility="Column" CanUserResizeRows="False"
                              SelectionMode="Single" SelectionUnit="FullRow">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource ElevatedBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
                                <Setter Property="FontSize" Value="10"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="12,10"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentGlowBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource CardHoverBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="CLIENTE" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="CNPJ" Binding="{Binding Cnpj}" Width="160">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="Consolas"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="DOCS/MES" Binding="{Binding DocsMonth}" Width="90"/>
                            <DataGridTextColumn Header="VALIDADOS" Binding="{Binding DocsValidated}" Width="90"/>
                            <DataGridTextColumn Header="PENDENTES" Binding="{Binding PendingDocs}" Width="90"/>
                            <DataGridTextColumn Header="STATUS" Binding="{Binding StatusText}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
