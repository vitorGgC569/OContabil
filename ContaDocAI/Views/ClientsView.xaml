<UserControl x:Class="ContaDocAI.Views.ClientsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ContaDocAI.Views"
             Loaded="OnLoaded">
    <StackPanel>
        <!-- ═══ Header ═══ -->
        <DockPanel Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBox Style="{StaticResource DarkTextBox}" Width="260" x:Name="searchBox"
                         TextChanged="OnSearch">
                    <TextBox.Tag>
                        <TextBlock Text="🔍  Buscar cliente..." Foreground="{StaticResource TextTertiaryBrush}"/>
                    </TextBox.Tag>
                </TextBox>
            </StackPanel>
            <Button DockPanel.Dock="Right" Style="{StaticResource BtnPrimary}" Content="➕  Novo Cliente"
                    HorizontalAlignment="Right" Click="OnAddClient"/>
        </DockPanel>

        <!-- ═══ Summary Stats ═══ -->
        <UniformGrid Columns="3" Margin="0,0,0,20">
            <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <Border Width="44" Height="44" CornerRadius="8" Background="{StaticResource AccentGlowBrush}">
                        <TextBlock Text="🏢" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="txtClientCount" Text="8" FontSize="26" FontWeight="ExtraBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Clientes ativos" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="4,0">
                <StackPanel Orientation="Horizontal">
                    <Border Width="44" Height="44" CornerRadius="8" Background="{StaticResource SuccessBgBrush}">
                        <TextBlock Text="📄" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="txtTotalDocs" Text="4.060" FontSize="26" FontWeight="ExtraBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Documentos no mes" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <Border Width="44" Height="44" CornerRadius="8" Background="{StaticResource WarningBgBrush}">
                        <TextBlock Text="⏳" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="txtPendingTotal" Text="98" FontSize="26" FontWeight="ExtraBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Documentos pendentes" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ═══ Client Cards ═══ -->
        <ItemsControl x:Name="clientsPanel">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardStyle}" Width="320" Margin="0,0,12,12" Cursor="Hand">
                        <StackPanel>
                            <!-- Header -->
                            <DockPanel Margin="0,0,0,12">
                                <Border Width="40" Height="40" CornerRadius="20"
                                        Background="{Binding Color, Converter={x:Static views:Converters.StringToColor}}">
                                    <TextBlock Text="{Binding Initials}" FontSize="13" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource TextPrimaryBrush}" MaxWidth="180"/>
                                    <TextBlock Text="{Binding Cnpj}" FontSize="10" FontFamily="Consolas"
                                               Foreground="{StaticResource TextTertiaryBrush}"/>
                                </StackPanel>
                                <Border DockPanel.Dock="Right" CornerRadius="10" Padding="8,3"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Background="{Binding BadgeBg}">
                                    <TextBlock Text="{Binding StatusText}" FontSize="9" FontWeight="SemiBold"
                                               Foreground="{Binding BadgeFg}"/>
                                </Border>
                            </DockPanel>

                            <!-- Progress -->
                            <DockPanel Margin="0,0,0,4">
                                <TextBlock Text="Progresso" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"/>
                                <TextBlock DockPanel.Dock="Right" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right">
                                    <TextBlock.Text>
                                        <Binding Path="ValidationPercent" StringFormat="{}{0}%"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DockPanel>
                            <Border Height="4" CornerRadius="2" Background="{StaticResource ElevatedBrush}" Margin="0,0,0,14">
                                <Border Height="4" CornerRadius="2" HorizontalAlignment="Left"
                                        Width="{Binding ProgressWidth}" Background="{Binding ProgressColor}"/>
                            </Border>

                            <!-- Stats Row -->
                            <UniformGrid Columns="3">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding DocsMonth}" FontSize="16" FontWeight="ExtraBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Docs/Mes" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding DocsValidated}" FontSize="16" FontWeight="ExtraBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Validados" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding PendingDocs}" FontSize="16" FontWeight="ExtraBold"
                                               Foreground="{Binding PendingColor}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Pendentes" FontSize="9" Foreground="{StaticResource TextTertiaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
