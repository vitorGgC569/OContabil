<UserControl x:Class="ContaDocAI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ GLiNER 2 Config ═══ -->
        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardStyle}">
            <StackPanel>
                <DockPanel Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="🧠  Motor de IA — GLiNER 2" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Configuracoes do modelo de extracao" FontSize="12"
                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                    </StackPanel>
                    <Border DockPanel.Dock="Right" Background="{StaticResource SuccessBgBrush}" CornerRadius="10"
                            Padding="10,4" VerticalAlignment="Top" BorderBrush="#4D10b981" BorderThickness="1">
                        <TextBlock Text="Online" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}"/>
                    </Border>
                </DockPanel>

                <TextBlock Text="Modelo" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <ComboBox Background="{StaticResource InputBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                          FontSize="12" Padding="8,6" SelectedIndex="0" Margin="0,0,0,14">
                    <ComboBoxItem>fastino/gliner2-base-v1 (205M params)</ComboBoxItem>
                    <ComboBoxItem>fastino/gliner2-large-v1 (340M params)</ComboBoxItem>
                </ComboBox>

                <TextBlock Text="Threshold de Confianca Global" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <DockPanel Margin="0,0,0,14">
                    <TextBlock DockPanel.Dock="Right" x:Name="thresholdText" Text="80%" FontSize="12" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    <Slider Minimum="50" Maximum="99" Value="80" TickFrequency="1" IsSnapToTickEnabled="True"
                            ValueChanged="OnThresholdChanged"/>
                </DockPanel>

                <TextBlock Text="Batch Size" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBox Style="{StaticResource DarkTextBox}" Text="8" Margin="0,0,0,4"/>
                <TextBlock Text="Documentos por lote (recomendado: 8 para CPU)" FontSize="10"
                           Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,14"/>

                <TextBlock Text="Dispositivo" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <ComboBox Background="{StaticResource InputBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                          FontSize="12" Padding="8,6" SelectedIndex="0" Margin="0,0,0,16">
                    <ComboBoxItem>CPU (Recomendado)</ComboBoxItem>
                    <ComboBoxItem>CUDA (GPU NVIDIA)</ComboBoxItem>
                </ComboBox>

                <Button Style="{StaticResource BtnSecondary}" Content="💾  Salvar" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <!-- ═══ OCR Config ═══ -->
        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource CardStyle}">
            <StackPanel>
                <DockPanel Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="📸  Motor de OCR" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Configuracoes de leitura optica" FontSize="12"
                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                    </StackPanel>
                    <Border DockPanel.Dock="Right" Background="{StaticResource SuccessBgBrush}" CornerRadius="10"
                            Padding="10,4" VerticalAlignment="Top" BorderBrush="#4D10b981" BorderThickness="1">
                        <TextBlock Text="Ativo" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}"/>
                    </Border>
                </DockPanel>

                <TextBlock Text="Engine de OCR" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <ComboBox Background="{StaticResource InputBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                          FontSize="12" Padding="8,6" SelectedIndex="0" Margin="0,0,0,14">
                    <ComboBoxItem>PaddleOCR (Recomendado)</ComboBoxItem>
                    <ComboBoxItem>Tesseract OCR</ComboBoxItem>
                    <ComboBoxItem>EasyOCR</ComboBoxItem>
                </ComboBox>

                <TextBlock Text="Idiomas" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBox Style="{StaticResource DarkTextBox}" Text="pt, en" Margin="0,0,0,14"/>

                <TextBlock Text="Pre-processamento de Imagem" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                <CheckBox Content="Correcao de rotacao automatica" IsChecked="True"
                          Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                <CheckBox Content="Binarizacao adaptativa" IsChecked="True"
                          Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                <CheckBox Content="Remocao de ruido" IsChecked="True"
                          Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                <CheckBox Content="Super-resolucao (lento)"
                          Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,14"/>

                <Button Style="{StaticResource BtnSecondary}" Content="💾  Salvar" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <!-- ═══ Privacy / LGPD ═══ -->
        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="🔒  Privacidade e LGPD" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                <TextBlock Text="Seguranca e conformidade de dados" FontSize="12"
                           Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,16"/>

                <!-- Green status items -->
                <Border Background="{StaticResource SuccessBgBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8"
                        BorderBrush="#3310b981" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✅" FontSize="14" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="Processamento 100% Local" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource SuccessBrush}"/>
                            <TextBlock Text="Nenhum dado e enviado para APIs externas" FontSize="10"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource SuccessBgBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8"
                        BorderBrush="#3310b981" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✅" FontSize="14" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="Modelo GLiNER 2 Offline" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource SuccessBrush}"/>
                            <TextBlock Text="IA roda sem conexao com internet" FontSize="10"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource SuccessBgBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,16"
                        BorderBrush="#3310b981" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✅" FontSize="14" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="Dados Criptografados (AES-256)" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource SuccessBrush}"/>
                            <TextBlock Text="Documentos armazenados com seguranca" FontSize="10"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="Retencao de Documentos" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <ComboBox Background="{StaticResource InputBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                          FontSize="12" Padding="8,6" SelectedIndex="1">
                    <ComboBoxItem>30 dias</ComboBoxItem>
                    <ComboBoxItem>90 dias</ComboBoxItem>
                    <ComboBoxItem>180 dias</ComboBoxItem>
                    <ComboBoxItem>365 dias</ComboBoxItem>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- ═══ Notifications ═══ -->
        <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="🔔  Notificacoes" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                <TextBlock Text="Alertas e comunicacoes" FontSize="12"
                           Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,16"/>

                <CheckBox Content="Email ao completar lote" IsChecked="True"
                          Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,10"/>
                <CheckBox Content="Alerta de erros de OCR" IsChecked="True"
                          Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,10"/>
                <CheckBox Content="Resumo diario por email"
                          Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,10"/>
                <CheckBox Content="Webhook para integracoes" IsChecked="True"
                          Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,16"/>

                <TextBlock Text="Email de Notificacoes" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBox Style="{StaticResource DarkTextBox}" Text="ricardo@contabilidade.com.br" Margin="0,0,0,16"/>

                <Button Style="{StaticResource BtnSecondary}" Content="💾  Salvar" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
