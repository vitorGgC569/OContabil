<Window x:Class="OContabil.Views.NewClientDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OContabil — Novo Cliente" Height="620" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgPrimary}"
        Icon="/Assets/logo.png"
        FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <!-- CNPJ Lookup Section -->
            <Border Background="{DynamicResource BgCard}" CornerRadius="8"
                    BorderBrush="{DynamicResource Border}" BorderThickness="1"
                    Padding="24,20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Buscar Empresa" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                    <TextBlock Text="Digite o CNPJ para preencher automaticamente via Receita Federal"
                               FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,14"
                               TextWrapping="Wrap"/>

                    <DockPanel>
                        <Button x:Name="btnLookup" DockPanel.Dock="Right" Style="{DynamicResource BtnPrimary}"
                                Content="Consultar" Click="OnLookup" Margin="8,0,0,0"
                                Padding="16,7"/>
                        <TextBox x:Name="txtCnpj" Style="{DynamicResource InputBox}"
                                 MaxLength="18" LostFocus="OnCnpjLostFocus"/>
                    </DockPanel>

                    <TextBlock x:Name="txtCnpjHint" Text="" FontSize="10" Margin="0,4,0,0"
                               Foreground="{DynamicResource TextMuted}"/>

                    <!-- Loading -->
                    <TextBlock x:Name="txtLoading" Text="Consultando Receita Federal..."
                               FontSize="11" Foreground="{DynamicResource Accent}"
                               Margin="0,6,0,0" Visibility="Collapsed"/>

                    <!-- Company Info Card (shown after lookup) -->
                    <Border x:Name="pnlCompanyInfo" Visibility="Collapsed"
                            Background="{DynamicResource BgElevated}" CornerRadius="6"
                            Padding="14" Margin="0,12,0,0">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,4">
                                <TextBlock x:Name="txtSituacao" Text="" FontSize="10" FontWeight="SemiBold"
                                           DockPanel.Dock="Right" Padding="6,2" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtRazaoSocial" Text="" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                            </DockPanel>
                            <TextBlock x:Name="txtFantasia" Text="" FontSize="11"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6"/>
                            <TextBlock x:Name="txtAtividade" Text="" FontSize="10.5"
                                       Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                            <TextBlock x:Name="txtEndereco" Text="" FontSize="10.5"
                                       Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="txtCapital" Text="" FontSize="10.5"
                                       Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Form Section -->
            <Border Background="{DynamicResource BgCard}" CornerRadius="8"
                    BorderBrush="{DynamicResource Border}" BorderThickness="1"
                    Padding="24,20">
                <StackPanel>
                    <TextBlock Text="Dados do Cliente" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,14"/>

                    <!-- Nome -->
                    <TextBlock Text="Razao Social *" FontSize="11.5" FontWeight="Medium"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtName" Style="{DynamicResource InputBox}" Margin="0,0,0,12"/>

                    <!-- Email -->
                    <TextBlock Text="Email" FontSize="11.5" FontWeight="Medium"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtEmail" Style="{DynamicResource InputBox}" Margin="0,0,0,12"/>

                    <!-- Telefone -->
                    <TextBlock Text="Telefone" FontSize="11.5" FontWeight="Medium"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtPhone" Style="{DynamicResource InputBox}" Margin="0,0,0,12"
                             MaxLength="15"/>

                    <!-- Regime -->
                    <TextBlock Text="Regime Tributario" FontSize="11.5" FontWeight="Medium"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbRegime" Padding="8,6" FontSize="11.5" Margin="0,0,0,16"
                              Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextPrimary}"
                              SelectedIndex="0">
                        <ComboBoxItem>Simples Nacional</ComboBoxItem>
                        <ComboBoxItem>Lucro Presumido</ComboBoxItem>
                        <ComboBoxItem>Lucro Real</ComboBoxItem>
                    </ComboBox>

                    <!-- Error -->
                    <TextBlock x:Name="txtError" Text="" FontSize="11"
                               Foreground="{DynamicResource Error}" Margin="0,0,0,10"
                               Visibility="Collapsed" TextWrapping="Wrap"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{DynamicResource BtnGhost}" Content="Cancelar"
                                Click="OnCancel" Margin="0,0,8,0"/>
                        <Button Style="{DynamicResource BtnPrimary}" Content="Salvar Cliente"
                                Click="OnSave"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
