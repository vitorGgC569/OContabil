<UserControl x:Class="OContabil.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI"
             Loaded="OnLoaded">
    <StackPanel>
        <!-- ═══ Stat Cards ═══ -->
        <UniformGrid Columns="4" Margin="0,0,0,28">
            <Border Style="{DynamicResource Card}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Total Documentos" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock x:Name="statDocs" Text="0" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,6,0,0"/>
                    <TextBlock Text="no periodo atual" FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource Card}" Margin="5,0">
                <StackPanel>
                    <TextBlock Text="Validados" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock x:Name="statValidated" Text="0" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource Success}" Margin="0,6,0,0"/>
                    <TextBlock x:Name="statValPct" Text="" FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource Card}" Margin="5,0">
                <StackPanel>
                    <TextBlock Text="Pendentes" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock x:Name="statPending" Text="0" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource Warning}" Margin="0,6,0,0"/>
                    <TextBlock Text="aguardando revisao" FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource Card}" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="Clientes Ativos" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                    <TextBlock x:Name="statClients" Text="0" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,6,0,0"/>
                    <TextBlock Text="empresas cadastradas" FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ═══ Recent Documents Table ═══ -->
        <Border Style="{DynamicResource Card}" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Documentos Recentes" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,16"/>

                <DataGrid x:Name="gridRecent" AutoGenerateColumns="False" IsReadOnly="True"
                          Background="Transparent" BorderThickness="0"
                          Foreground="{DynamicResource TextPrimary}"
                          FontSize="12" RowBackground="Transparent" AlternatingRowBackground="Transparent"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource Border}"
                          HeadersVisibility="Column" CanUserResizeRows="False" MaxHeight="360">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource BgElevated}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                            <Setter Property="FontSize" Value="10"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="12,6"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource BgHover}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ARQUIVO" Binding="{Binding Filename, Mode=OneWay}" Width="*"/>
                        <DataGridTextColumn Header="TIPO" Binding="{Binding DocumentType, Mode=OneWay}" Width="90"/>
                        <DataGridTextColumn Header="CLIENTE" Binding="{Binding ClientName, Mode=OneWay}" Width="200"/>
                        <DataGridTextColumn Header="STATUS" Binding="{Binding StatusDisplay, Mode=OneWay}" Width="100"/>
                        <DataGridTextColumn Header="DATA" Binding="{Binding DateStr, Mode=OneWay}" Width="100"/>
                        <DataGridTextColumn Header="TAMANHO" Binding="{Binding SizeStr, Mode=OneWay}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

        <!-- ═══ Clients Summary ═══ -->
        <Border Style="{DynamicResource Card}">
            <StackPanel>
                <TextBlock Text="Clientes — Resumo" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,16"/>
                <DataGrid x:Name="gridClients" AutoGenerateColumns="False" IsReadOnly="True"
                          Background="Transparent" BorderThickness="0"
                          Foreground="{DynamicResource TextPrimary}"
                          FontSize="12" RowBackground="Transparent" AlternatingRowBackground="Transparent"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource Border}"
                          HeadersVisibility="Column" CanUserResizeRows="False">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource BgElevated}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                            <Setter Property="FontSize" Value="10"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="12,6"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource BgHover}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="EMPRESA" Binding="{Binding Name, Mode=OneWay}" Width="*"/>
                        <DataGridTextColumn Header="CNPJ" Binding="{Binding Cnpj, Mode=OneWay}" Width="170">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="DOCS" Binding="{Binding DocumentCount, Mode=OneWay}" Width="70"/>
                        <DataGridTextColumn Header="VALIDADOS" Binding="{Binding ValidatedCount, Mode=OneWay}" Width="90"/>
                        <DataGridTextColumn Header="PENDENTES" Binding="{Binding PendingCount, Mode=OneWay}" Width="90"/>
                        <DataGridTextColumn Header="REGIME" Binding="{Binding TaxRegime, Mode=OneWay}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
