<Window x:Class="OContabil.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="OContabil"
        Height="800" Width="1350" MinHeight="600" MinWidth="1000"
        Background="{DynamicResource BgPrimary}"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Icon="/Assets/logo.png"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- â•â•â• Sidebar â•â•â• -->
        <Border Grid.Column="0" Background="{DynamicResource BgSidebar}"
                BorderBrush="{DynamicResource Border}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Brand -->
                <Border DockPanel.Dock="Top" Padding="20,18,20,14"
                        BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/logo.png" Width="28" Height="28" Margin="0,0,10,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="OContabil" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Gestao Documental" FontSize="9.5"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,1,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- User Footer -->
                <Border DockPanel.Dock="Bottom" Padding="14,12"
                        BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0">
                    <DockPanel>
                        <Border Width="32" Height="32" CornerRadius="16"
                                Background="{DynamicResource Accent}">
                            <TextBlock x:Name="txtUserInitials" Text="AD" FontSize="11" FontWeight="SemiBold"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="txtUserName" Text="" FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock x:Name="txtUserRole" Text="" FontSize="10"
                                       Foreground="{DynamicResource TextMuted}"/>
                        </StackPanel>
                        <Button DockPanel.Dock="Right" Style="{DynamicResource BtnGhost}"
                                Content="Sair" FontSize="10" Padding="8,4"
                                Click="OnLogout" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- Navigation -->
                <ScrollViewer VerticalScrollBarVisibility="Hidden" Margin="0,12">
                    <StackPanel Margin="6,0">
                        <TextBlock Text="GERAL" FontSize="9.5" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMuted}" Margin="14,0,0,6"/>

                        <RadioButton x:Name="navDash" Style="{DynamicResource NavBtn}" IsChecked="True"
                                     Checked="OnNav" Tag="Dashboard">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="ViewDashboard" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Painel" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{DynamicResource NavBtn}" Checked="OnNav" Tag="Documents">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="FileDocumentOutline" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Documentos" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{DynamicResource NavBtn}" Checked="OnNav" Tag="Clients">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="AccountMultiple" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Clientes" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <TextBlock Text="ADMINISTRACAO" FontSize="9.5" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMuted}" Margin="14,20,0,6"/>

                        <RadioButton x:Name="navUsers" Style="{DynamicResource NavBtn}" Checked="OnNav" Tag="Users">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="ShieldAccount" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Usuarios" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{DynamicResource NavBtn}" Checked="OnNav" Tag="Settings">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Cog" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Configuracoes" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- â•â•â• Main Content â•â•â• -->
        <DockPanel Grid.Column="1">
            <!-- Header -->
            <Border DockPanel.Dock="Top" Padding="28,14" Background="{DynamicResource BgSidebar}"
                    BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                <DockPanel>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="txtPageTitle" Text="Painel" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock x:Name="txtPageSub" Text="Visao geral" FontSize="11"
                                   Foreground="{DynamicResource TextMuted}" Margin="0,1,0,0"/>
                    </StackPanel>
                    <!-- Top Right Actions -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{DynamicResource BtnGhost}" Content="Alternar Tema" 
                                Margin="0,0,12,0" Padding="12,6" Click="OnToggleTheme" VerticalAlignment="Center"/>
                        <TextBox Style="{DynamicResource InputBox}" Width="240" FontSize="11.5" VerticalAlignment="Center" ToolTip="Em breve"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Page Host -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ContentControl x:Name="pageHost" Margin="28,24"/>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</Window>
