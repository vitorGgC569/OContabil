<Window x:Class="OContabil.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Senha do Certificado" Height="200" Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgPrimary}"
        Icon="/Assets/logo.png"
        FontFamily="Segoe UI">
    <Border Margin="16" Background="{DynamicResource BgCard}"
            CornerRadius="8" BorderBrush="{DynamicResource Border}"
            BorderThickness="1" Padding="20,16">
        <StackPanel>
            <TextBlock Text="Digite a senha do certificado:" FontSize="12"
                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10"/>
            <PasswordBox x:Name="txtPassword" Style="{DynamicResource InputPassword}" Margin="0,0,0,14"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{DynamicResource BtnGhost}" Content="Cancelar" Click="OnCancel" Margin="0,0,8,0"/>
                <Button Style="{DynamicResource BtnPrimary}" Content="OK" Click="OnOk"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
