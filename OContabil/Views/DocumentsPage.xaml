<UserControl x:Class="OContabil.Views.DocumentsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             FontFamily="Segoe UI" Loaded="OnLoaded">
    <UserControl.Resources>
        <ContextMenu x:Key="RowMenu" FontFamily="Segoe UI" FontSize="12">
            <MenuItem Header="Reanalisar Documento (IA)" Click="OnReanalyzeDoc"/>
            <Separator/>
            <MenuItem Header="Excluir Documento" Foreground="Red" Click="OnDeleteDoc"/>
        </ContextMenu>
    </UserControl.Resources>

    <StackPanel>
        <!-- Toolbar -->
        <DockPanel Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="txtSearch" Style="{DynamicResource InputBox}" Width="280"
                         TextChanged="OnFilter" FontSize="11.5"/>
                <ComboBox x:Name="cmbType" Width="130" Margin="10,0,0,0"
                          SelectionChanged="OnFilter" FontSize="11.5"
                          Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextPrimary}"
                          Padding="8,6"/>
                <ComboBox x:Name="cmbStatus" Width="130" Margin="10,0,0,0"
                          SelectionChanged="OnFilter" FontSize="11.5"
                          Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextPrimary}"
                          Padding="8,6"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Style="{DynamicResource BtnGhost}" Content="Exportar Dominio (.txt)" 
                        Click="OnExport" Margin="0,0,8,0"/>
                <Button Style="{DynamicResource BtnPrimary}"
                        Content="Importar Documentos" Click="OnImport"/>
            </StackPanel>
        </DockPanel>

        <!-- Table -->
        <Border Style="{DynamicResource Card}" Padding="0">
            <DataGrid x:Name="gridDocs" AutoGenerateColumns="False" IsReadOnly="True"
                      Background="Transparent" BorderThickness="0"
                      Foreground="{DynamicResource TextPrimary}"
                      FontSize="12" RowBackground="Transparent" AlternatingRowBackground="Transparent"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource Border}"
                      HeadersVisibility="Column" CanUserResizeRows="False" CanUserSortColumns="True">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource BgElevated}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="14,10"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="14,8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <EventSetter Event="MouseDoubleClick" Handler="OnRowDoubleClick"/>
                        <Setter Property="ContextMenu" Value="{StaticResource RowMenu}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BgHover}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ARQUIVO" Binding="{Binding Filename, Mode=OneWay}" Width="*"/>
                    <DataGridTextColumn Header="TIPO" Binding="{Binding DocumentType, Mode=OneWay}" Width="80"/>
                    <DataGridTextColumn Header="CLIENTE" Binding="{Binding Client.Name, TargetNullValue='—', Mode=OneWay}" Width="220"/>
                    <DataGridTextColumn Header="STATUS" Binding="{Binding StatusDisplay, Mode=OneWay}" Width="100"/>
                    <DataGridTextColumn Header="CONFIANCA" Binding="{Binding ConfidenceScore, StringFormat={}{0:P0}, TargetNullValue='—', Mode=OneWay}" Width="90"/>
                    <DataGridTextColumn Header="DATA" Binding="{Binding UploadedAt, StringFormat={}{0:dd/MM/yyyy HH:mm}, Mode=OneWay}" Width="100"/>
                    <DataGridTextColumn Header="TAMANHO" Binding="{Binding FileSizeDisplay, Mode=OneWay}" Width="80"/>
                    
                    <DataGridTemplateColumn Header="AÇÕES" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Click="OnReanalyzeDoc" 
                                            Background="Transparent" BorderThickness="0" 
                                            Foreground="{DynamicResource TextMuted}" 
                                            Cursor="Hand" Margin="0,0,10,0" ToolTip="Reanalisar com IA">
                                        <iconPacks:PackIconMaterial Kind="Sync" Width="14" Height="14" IsHitTestVisible="False"/>
                                    </Button>
                                    <Button Click="OnDeleteDoc" 
                                            Background="Transparent" BorderThickness="0" 
                                            Foreground="IndianRed" 
                                            Cursor="Hand" ToolTip="Excluir Permanentemente">
                                        <iconPacks:PackIconMaterial Kind="DeleteOutline" Width="14" Height="14" IsHitTestVisible="False"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Count -->
        <TextBlock x:Name="txtCount" Text="" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,10,0,0"/>
    </StackPanel>
</UserControl>
