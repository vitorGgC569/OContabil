<UserControl x:Class="OContabil.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Motor IA -->
        <Border Grid.Row="0" Grid.Column="0" Style="{DynamicResource Card}">
            <StackPanel>
                <TextBlock Text="Motor de IA" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                <TextBlock Text="Configuracoes do GLiNER 2 / ONNX Runtime" FontSize="11"
                           Foreground="{DynamicResource TextMuted}" Margin="0,0,0,20"/>

                <TextBlock Text="Modelo" FontSize="11.5" FontWeight="Medium"
                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                <ComboBox x:Name="cmbModel" SelectedIndex="0" Padding="8,6" FontSize="11.5" Margin="0,0,0,16"
                          Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextPrimary}"
                          SelectionChanged="OnModelChanged">
                    <ComboBoxItem Tag="fastino/gliner2-base-v1">gliner2-base-v1 (205M params)</ComboBoxItem>
                    <ComboBoxItem Tag="fastino/gliner2-large-v1">gliner2-large-v1 (340M params)</ComboBoxItem>
                </ComboBox>

                <TextBlock Text="Threshold de Confianca" FontSize="11.5" FontWeight="Medium"
                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                <TextBox x:Name="txtThreshold" Style="{DynamicResource InputBox}" Text="0.80" Width="100"
                         HorizontalAlignment="Left" Margin="0,0,0,16" LostFocus="OnThresholdChanged"/>

                <TextBlock Text="Python" FontSize="11.5" FontWeight="Medium"
                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                <TextBlock x:Name="txtPythonStatus" Text="" FontSize="10.5"
                           Foreground="{DynamicResource TextMuted}" FontFamily="Consolas"/>
            </StackPanel>
        </Border>

        <!-- Certificado Digital -->
        <Border Grid.Row="0" Grid.Column="2" Style="{DynamicResource Card}">
            <StackPanel>
                <TextBlock Text="Certificado Digital" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                <TextBlock Text="Certificado A1 (.pfx) para acesso a SEFAZ" FontSize="11"
                           Foreground="{DynamicResource TextMuted}" Margin="0,0,0,16"/>

                <!-- Certificate Status -->
                <Border x:Name="pnlCertStatus" Background="{DynamicResource BgElevated}"
                        CornerRadius="6" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock x:Name="txtCertStatus" Text="Nenhum certificado carregado"
                                   FontSize="12" FontWeight="Medium"
                                   Foreground="{DynamicResource TextMuted}"/>
                        <TextBlock x:Name="txtCertInfo" Text="" FontSize="10"
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Button Style="{DynamicResource BtnPrimary}" Content="Carregar Certificado (.pfx)"
                        Click="OnLoadCert" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <!-- OCR -->
        <Border Grid.Row="2" Grid.Column="0" Style="{DynamicResource Card}">
            <StackPanel>
                <TextBlock Text="OCR" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                <TextBlock Text="Leitura optica de documentos" FontSize="11"
                           Foreground="{DynamicResource TextMuted}" Margin="0,0,0,20"/>

                <TextBlock Text="Engine" FontSize="11.5" FontWeight="Medium"
                           Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                <ComboBox SelectedIndex="0" Padding="8,6" FontSize="11.5" Margin="0,0,0,16"
                          Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextPrimary}">
                    <ComboBoxItem>PyMuPDF (PDF nativo)</ComboBoxItem>
                    <ComboBoxItem>Tesseract OCR (imagens)</ComboBoxItem>
                </ComboBox>

                <CheckBox Content="Correcao de rotacao" IsChecked="True"
                          Foreground="{DynamicResource TextPrimary}" FontSize="11.5" Margin="0,0,0,8"/>
                <CheckBox Content="Remocao de ruido" IsChecked="True"
                          Foreground="{DynamicResource TextPrimary}" FontSize="11.5"/>
            </StackPanel>
        </Border>

        <!-- Integracoes -->
        <Border Grid.Row="2" Grid.Column="2" Style="{DynamicResource Card}">
            <StackPanel>
                <TextBlock Text="Integracoes" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                <TextBlock Text="APIs e servicos conectados" FontSize="11"
                           Foreground="{DynamicResource TextMuted}" Margin="0,0,0,16"/>

                <Border Background="{DynamicResource SuccessBg}" CornerRadius="6" Padding="10" Margin="0,0,0,8"
                        BorderBrush="#1A2da565" BorderThickness="1">
                    <DockPanel>
                        <TextBlock Text="✓" Foreground="{DynamicResource Success}" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock Text="BrasilAPI — Consulta CNPJ" FontSize="11.5" FontWeight="Medium"
                                       Foreground="{DynamicResource Success}"/>
                            <TextBlock Text="Preenchimento automatico via Receita Federal" FontSize="10"
                                       Foreground="{DynamicResource TextMuted}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Background="{DynamicResource BgElevated}" CornerRadius="6" Padding="10" Margin="0,0,0,8"
                        BorderBrush="{DynamicResource Border}" BorderThickness="1">
                    <DockPanel>
                        <TextBlock Text="○" Foreground="{DynamicResource TextMuted}" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock Text="SEFAZ — Distribuicao DF-e" FontSize="11.5" FontWeight="Medium"
                                       Foreground="{DynamicResource TextSecondary}"/>
                            <TextBlock Text="Requer certificado digital A1" FontSize="10"
                                       Foreground="{DynamicResource TextMuted}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Background="{DynamicResource BgElevated}" CornerRadius="6" Padding="10"
                        BorderBrush="{DynamicResource Border}" BorderThickness="1">
                    <DockPanel>
                        <TextBlock Text="○" Foreground="{DynamicResource TextMuted}" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock Text="eSocial / EFD" FontSize="11.5" FontWeight="Medium"
                                       Foreground="{DynamicResource TextSecondary}"/>
                            <TextBlock Text="Em desenvolvimento" FontSize="10"
                                       Foreground="{DynamicResource TextMuted}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Seguranca -->
        <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Style="{DynamicResource Card}">
            <StackPanel>
                <TextBlock Text="Seguranca e LGPD" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,14"/>
                <UniformGrid Columns="3">
                    <Border Background="{DynamicResource SuccessBg}" CornerRadius="6" Padding="12" Margin="0,0,8,0"
                            BorderBrush="#1A2da565" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Processamento 100% Local" FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource Success}"/>
                            <TextBlock Text="Nenhum dado enviado para nuvem" FontSize="10"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource SuccessBg}" CornerRadius="6" Padding="12" Margin="4,0"
                            BorderBrush="#1A2da565" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Controle de Acesso por Perfil" FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource Success}"/>
                            <TextBlock Text="Admin / Operador / Visualizador" FontSize="10"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource SuccessBg}" CornerRadius="6" Padding="12" Margin="8,0,0,0"
                            BorderBrush="#1A2da565" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Banco de Dados Local" FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource Success}"/>
                            <TextBlock Text="SQLite em %LocalAppData%\OContabil" FontSize="10"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
