<Window x:Class="OContabil.Views.DocumentReviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Revisão de Documento" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgPrimary}"
        Foreground="{DynamicResource TextPrimary}"
        FontFamily="Segoe UI"
        Loaded="OnLoaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock x:Name="txtFilename" Text="Filename.pdf" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"/>
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Border x:Name="badgeType" CornerRadius="4" Padding="6,2" Background="{DynamicResource InfoBg}">
                    <TextBlock x:Name="txtType" Text="NFS-e" Foreground="{DynamicResource Info}" FontSize="12" FontWeight="Bold"/>
                </Border>
                <Border x:Name="badgeStatus" CornerRadius="4" Padding="6,2" Margin="8,0,0,0">
                    <TextBlock x:Name="txtStatus" Text="ReadyForReview" FontSize="12" FontWeight="Bold"/>
                </Border>
                <TextBlock x:Name="txtConfidence" Text="Confiança: 95%" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
            </StackPanel>
        </StackPanel>

        <!-- Side by Side Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Native Document Viewer -->
            <Border Grid.Column="0" Style="{DynamicResource Card}" Padding="0" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Documento Original" FontWeight="SemiBold" FontSize="14" Margin="16,16,16,12"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <wv2:WebView2 x:Name="docViewer" Grid.Row="1" />
                </Grid>
            </Border>

            <!-- Right: Extracted Data -->
            <Border Grid.Column="2" Style="{DynamicResource Card}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Texto Original (OCR)" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBox x:Name="txtOcr" Grid.Row="1" Style="{DynamicResource InputBox}" 
                             IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="11" Margin="0,0,0,16"/>

                    <TextBlock Grid.Row="2" Text="Dados Extraídos (JSON)" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBox x:Name="txtJson" Grid.Row="3" Style="{DynamicResource InputBox}" 
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="11"/>

                    <StackPanel Grid.Row="4" Margin="0,16,0,0">
                        <TextBlock Text="Status da Revisão" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="cmbStatus" Padding="8,6" FontSize="11.5"
                                  Background="{DynamicResource BgInput}" Foreground="{DynamicResource TextPrimary}">
                            <ComboBoxItem Content="Pendente" Tag="0"/>
                            <ComboBoxItem Content="Processando" Tag="1"/>
                            <ComboBoxItem Content="Revisar" Tag="2"/>
                            <ComboBoxItem Content="Validado" Tag="3"/>
                            <ComboBoxItem Content="Erro" Tag="4"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <DockPanel Grid.Row="2" Margin="0,24,0,0" LastChildFill="False">
            <Button Style="{DynamicResource BtnGhost}" Content="Cancelar" Click="OnCancel" DockPanel.Dock="Left" Width="100"/>
            <Button Style="{DynamicResource BtnPrimary}" Content="Aprovar Documento" Click="OnSave" DockPanel.Dock="Right" Width="180"/>
        </DockPanel>
    </Grid>
</Window>
